{
  "manifest_version": 3,
  "name": "Student PhishGuard MVP",
  "version": "1.0",
  "description": "Detects risky pages and teaches students why they are dangerous.",
  "permissions": [
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://mail.google.com/*"],
      "js": ["email_content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Student PhishGuard"
  }

}
